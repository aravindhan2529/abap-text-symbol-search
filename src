*-----------------------------------------------------------------------
* Program : ZTEXTPOOL_SEARCH
* Purpose : Search Text Symbols (Text Elements) across ABAP programs
* Author  : Aravindhan Chandran
* GitHub  : https://github.com/aravindhan2529/abap-text-symbol-search
*-----------------------------------------------------------------------
report ztextpool_search.

data:
  gv_program type rs38m-programm,
  gv_text    type textpool-entry.

selection-screen begin of block b1 with frame title text-001.
  select-options:
    so_prog for gv_program no intervals no-extension obligatory,
    so_lang    for sy-langu   no intervals no-extension default 'EN',
    so_text    for gv_text    no intervals no-extension.
selection-screen end of block b1.

class lcl_textpool_search definition final.
  public section.
    methods:
      execute,
      display_result.

  private section.
    types:
      begin of ty_program,
        pgmid    type tadir-pgmid,
        object   type tadir-object,
        obj_name type tadir-obj_name,
      end of ty_program.
    types:
      begin of ty_result,
        program type rs38m-programm,
        key     type textpool-key,
        text    type textpool-entry,
      end of ty_result.
    data:
      mt_programs type sorted table of ty_program
                    with unique key pgmid object obj_name,
      mt_textpool type standard table of textpool,
      mt_result   type standard table of ty_result.

endclass.

class lcl_textpool_search implementation.
  method execute.
    select pgmid,
           object,
           obj_name
      from tadir
      into table @mt_programs
      where pgmid    = 'R3TR'
        and obj_name in @so_prog.
    loop at mt_programs into data(ls_program).
      clear mt_textpool.
      read textpool ls_program-obj_name
        language so_lang-low
        into mt_textpool
        state 'A'.
      loop at mt_textpool into data(ls_textpool)
           where id = 'I'
             and entry cs so_text-low.
        append value ty_result(
                 program = ls_program-obj_name
                 key     = ls_textpool-key
                 text    = ls_textpool-entry )
          to mt_result.
      endloop.
    endloop.
  endmethod.

  method display_result.
    try.
        cl_salv_table=>factory(
          importing
            r_salv_table = data(lo_alv)
          changing
            t_table      = mt_result ).
        lo_alv->get_functions( )->set_all( abap_true ).
        lo_alv->display( ).
      catch cx_salv_msg into data(lx_error).
        message lx_error->get_text( ) type 'I'.
    endtry.
  endmethod.
endclass.

start-of-selection.
  data(lo_search) = new lcl_textpool_search( ).
  lo_search->execute( ).
  lo_search->display_result( ).
